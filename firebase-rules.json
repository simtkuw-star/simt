{
  "rules": {
    "teachers": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": false
      }
    },
    "students": {
      ".read": "auth != null && root.child('teachers').child(auth.uid).val() == true",
      "$uid": {
        ".read": "auth != null && (auth.uid == $uid || root.child('teachers').child(auth.uid).val() == true)",
        ".write": "auth != null && auth.uid == $uid",
        "work": {
          "rubric": {
            ".write": "auth != null && (auth.uid == $uid || root.child('teachers').child(auth.uid).val() == true)"
          },
          "rubricTotal": {
            ".write": "auth != null && (auth.uid == $uid || root.child('teachers').child(auth.uid).val() == true)"
          },
          "rubricLevel": {
            ".write": "auth != null && (auth.uid == $uid || root.child('teachers').child(auth.uid).val() == true)"
          },
          "teacherComment": {
            ".write": "auth != null && (auth.uid == $uid || root.child('teachers').child(auth.uid).val() == true)"
          },
          "submittedAt": {
            ".write": "auth != null && auth.uid == $uid"
          },
          "evaluatedAt": {
            ".write": "auth != null && (auth.uid == $uid || root.child('teachers').child(auth.uid).val() == true)"
          },
          "evaluatedBy": {
            ".write": "auth != null && (auth.uid == $uid || root.child('teachers').child(auth.uid).val() == true)"
          },
          "updatedAt": {
            ".write": "auth != null && (auth.uid == $uid || root.child('teachers').child(auth.uid).val() == true)"
          }
        }
      }
    },
    "siteStats": {
      ".read": false,
      "totalLogins": {
        ".write": "auth != null && newData.isNumber()"
      },
      "lastLoginAt": {
        ".write": "auth != null"
      },
      "lastStudents": {
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    }
  }
}
